{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/techjavelin/specter/schemas/specter-manifest.schema.json",
  "title": "SPECTER Manifest",
  "description": "Chain-of-custody manifest produced by the SPECTER forensic acquisition toolkit. This is the canonical contract for validating sealed evidence packages.",
  "type": "object",
  "required": [
    "specter_version",
    "run_id",
    "created_at",
    "completed_at",
    "examiner",
    "host",
    "phases",
    "files",
    "file_count",
    "total_bytes",
    "seal",
    "sealed"
  ],
  "properties": {
    "specter_version": {
      "type": "string",
      "description": "SPECTER manifest schema version.",
      "const": "2.0"
    },
    "run_id": {
      "type": "string",
      "description": "Unique acquisition run identifier. Format: {Hostname}-{UnixNano}.",
      "pattern": "^.+-\\d+$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when the acquisition started."
    },
    "completed_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when the seal was applied."
    },
    "examiner": {
      "type": "string",
      "minLength": 1,
      "description": "Name of the forensic examiner who initiated the acquisition."
    },
    "host": {
      "type": "object",
      "description": "Identity and hardware profile of the target system.",
      "required": ["hostname"],
      "properties": {
        "hostname": { "type": "string" },
        "serial": { "type": "string" },
        "manufacturer": { "type": "string" },
        "model": { "type": "string" },
        "os_caption": { "type": "string" },
        "os_version": { "type": "string" },
        "os_build": { "type": "string" },
        "os_arch": { "type": "string" },
        "os_edition": { "type": "string" },
        "total_ram_gb": { "type": "number" },
        "cpu": { "type": "string" }
      }
    },
    "capabilities": {
      "type": "object",
      "description": "Platform capabilities detected at acquisition time.",
      "properties": {
        "os_edition": { "type": "string" },
        "has_bitlocker_module": { "type": "boolean" },
        "has_manage_bde": { "type": "boolean" },
        "has_net_firewall": { "type": "boolean" }
      }
    },
    "phases": {
      "type": "object",
      "description": "Execution status and timing for each acquisition phase.",
      "patternProperties": {
        "^(MEMORY|VOLATILE|TRIAGE|DISK|SEAL)$": {
          "$ref": "#/$defs/phase_state"
        }
      },
      "additionalProperties": false
    },
    "files": {
      "type": "array",
      "description": "Complete inventory of every file in the evidence package.",
      "items": { "$ref": "#/$defs/file_hash" }
    },
    "file_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Total number of files in the evidence package."
    },
    "total_bytes": {
      "type": "integer",
      "minimum": 0,
      "description": "Sum of all file sizes in bytes."
    },
    "seal": {
      "$ref": "#/$defs/seal_document",
      "description": "Cryptographic integrity seal over the manifest."
    },
    "sealed": {
      "type": "boolean",
      "description": "Whether the evidence package has been sealed.",
      "const": true
    }
  },
  "additionalProperties": false,
  "$defs": {
    "file_hash": {
      "type": "object",
      "description": "A file entry in the evidence package. Files are either directly hashed (sha256) or verified by the acquisition tool (verified_by). Exactly one of sha256 or verified_by must be present.",
      "required": ["path", "size", "modified"],
      "properties": {
        "path": {
          "type": "string",
          "description": "Relative path from the evidence package root. Always uses forward slashes."
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$",
          "description": "SHA-256 hex digest computed by SPECTER during seal."
        },
        "size": {
          "type": "integer",
          "minimum": 0,
          "description": "File size in bytes."
        },
        "modified": {
          "type": "string",
          "format": "date-time",
          "description": "File modification timestamp (UTC, ISO 8601)."
        },
        "verified_by": {
          "type": "string",
          "description": "Tool that already verified this file's integrity (e.g. 'ewfacquire/ewfverify'). Present instead of sha256 for disk image segments."
        }
      },
      "oneOf": [
        { "required": ["sha256"] },
        { "required": ["verified_by"] }
      ],
      "additionalProperties": false
    },
    "phase_state": {
      "type": "object",
      "description": "Execution record for a single acquisition phase.",
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["pending", "running", "done", "failed", "skipped"]
        },
        "started_at": {
          "type": "string",
          "format": "date-time"
        },
        "completed_at": {
          "type": "string",
          "format": "date-time"
        },
        "error": {
          "type": "string",
          "description": "Error message if the phase failed."
        }
      },
      "additionalProperties": false
    },
    "seal_document": {
      "type": "object",
      "description": "HMAC-SHA256 integrity seal. The HMAC is computed over the JSON-serialized seal document (before hmac_sha256 and hmac_key_components are set).",
      "required": [
        "seal_version",
        "sealed_at",
        "run_id",
        "examiner",
        "hostname",
        "serial",
        "file_count",
        "total_bytes",
        "files",
        "hmac_sha256",
        "hmac_key_components"
      ],
      "properties": {
        "seal_version": {
          "type": "string",
          "const": "1.0"
        },
        "sealed_at": {
          "type": "string",
          "format": "date-time"
        },
        "run_id": { "type": "string" },
        "examiner": { "type": "string" },
        "hostname": { "type": "string" },
        "serial": { "type": "string" },
        "file_count": {
          "type": "integer",
          "minimum": 0
        },
        "total_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "files": {
          "type": "array",
          "items": { "$ref": "#/$defs/file_hash" }
        },
        "hmac_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$",
          "description": "HMAC-SHA256 hex digest over the seal document."
        },
        "hmac_key_components": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Fields used to derive the HMAC key, in order. Key = join with '|'."
        }
      },
      "additionalProperties": false
    }
  }
}
